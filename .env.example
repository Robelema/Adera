# Environment
NODE_ENV=development
PORT=3000

# Security
# TOKEN_ENCRYPTION_KEY must be exactly 32 characters long
TOKEN_ENCRYPTION_KEY=adera_token_secret_32_chars_long

# Google OAuth (for Cloud Backup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_URL=http://localhost:3000

# Webhooks
PAYMENT_WEBHOOK_SECRET=adera_secret_123

# Gemini API (handled by platform)
# GEMINI_API_KEY=
